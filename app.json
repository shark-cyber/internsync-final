{
  "expo": {
    "name": "InternSync",
    "slug": "internsync",
    "version": "1.1.5",
    "scheme": "internsync",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b0b0d",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.internsync.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.internsync.app",
      "adaptiveIcon": {
        "backgroundColor": "#0b0b0d",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "InternSync needs access to your photos to set your profile picture and upload your CV."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7d2098e9-899f-4674-b2c9-e94535868015"
      }
    }
  }
}
